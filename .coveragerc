[run]
source = src/
# The private _internal/ helpers are vendored from python-common (tested there); keep them
# out of the library's own coverage number.
omit =
    src/*/_internal/*

[report]
# Single source of truth for the coverage floor — read by pytest-cov in both the
# pre-commit `coverage-check` hook and the CI coverage gate (no duplicated literal).
fail_under = 80
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    @abstractmethod
    \.\.\.
